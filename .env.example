# PPT Master 环境配置
# Image/Video backend configuration via .env

IMAGE_BACKEND=openai

# --- Agnes API (FREE, recommended) ---
OPENAI_BASE_URL=https://apihub.agnes-ai.com/v1
OPENAI_API_KEY=sk-***...put_your_key_here
OPENAI_IMAGE_MODEL=agnes-image-2.1-flash
OPENAI_VIDEO_MODEL=agnes-video-2.0
IMAGE_DEFAULT_SIZE=1024x1024

# --- OpenAI (paid) ---
# OPENAI_API_KEY=sk-...
# OPENAI_IMAGE_MODEL=dall-e-3

# --- Gemini (free tier available) ---
# IMAGE_BACKEND=gemini
# GEMINI_API_KEY=...

# --- SiliconFlow ---
# IMAGE_BACKEND=openai
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# OPENAI_API_KEY=sk-...

#
# ⚠️ CRITICAL: API Key with special chars
# NEVER use `source .env` or `export $(cat .env)` — bash splits on $ and special chars.
# Always read the key inside Python:
#   with open(".env") as f:
#       for line in f:
#           if line.startswith("OPENAI_API_KEY"):
#               key = line.strip().split("=", 1)[1]
#               break
